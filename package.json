{
  "name": "kabu_ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build && npm run copy",
    "copy": "cp -r public .next/standalone/ && mkdir -p .next/standalone/.next && cp -r .next/static .next/standalone/.next/",
    "start": "node .next/standalone/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run __tests__/unit",
    "test:integration": "vitest run __tests__/integration",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:system": "playwright test",
    "test:system:login": "playwright test __tests__/e2e/login.spec.ts __tests__/e2e/system-login.spec.ts",
    "test:system:chat": "playwright test __tests__/e2e/system-chat.spec.ts",
    "test:system:valuation": "playwright test __tests__/e2e/system-valuation.spec.ts",
    "test:system:smoke": "playwright test __tests__/e2e/all-pages-smoke.spec.ts __tests__/e2e/top-page.spec.ts __tests__/e2e/stocks-news-loading-alignment.spec.ts",
    "test:all": "npm run test && npm run test:system"
  },
